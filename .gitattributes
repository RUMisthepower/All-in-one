# 🌐 Автоопределение типов файлов
* text=auto

# 📝 Текстовые файлы (принудительно LF)
*.json text eol=lf
*.lang text eol=lf
*.mcmeta text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.properties text eol=lf

# 🖼 Бинарные файлы (запрет текстовой обработки)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.psd binary
*.kra binary
*.xcf binary
*.ttf binary
*.ogg binary
*.mp3 binary
*.dat binary
